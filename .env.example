# ============================================================
# Grack_Trade — ค่า Supabase ที่ต้องตั้ง
# ============================================================
# หมายเหตุสำคัญ: โปรเจกต์นี้เป็น "ไฟล์ HTML เดียว ไม่มี build step (ไม่ใช้ Node)"
# ดังนั้นจึงไม่ได้อ่านไฟล์ .env จริง ๆ ตอนรัน
#
# ให้นำค่า 2 ตัวข้างล่างนี้ไป "วางในโค้ด" ที่บล็อก [SUPABASE CONFIG]
# ซึ่งอยู่บนสุดของไฟล์  GradeCalculatorApp.jsx  (แล้วรัน python3 build.py)
# หรือแก้ที่ index.html ตรง ๆ ก็ได้ (ค้นหาคำว่า SUPABASE_URL)
#
# anon key เป็น public key ใส่ในหน้าเว็บได้ (ไม่มีระบบล็อกอิน · RLS เปิด public อยู่แล้ว)
# หาได้ที่: Supabase project → Project Settings → API
# ============================================================

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ------------------------------------------------------------
# (ไม่บังคับ) Gemini — AI ช่วยวิเคราะห์แนวโน้มสายอาชีพ
# วางในบล็อก [GEMINI CONFIG] บนสุดของ GradeCalculatorApp.jsx
# ⚠️ คีย์นี้จะโผล่ในหน้าเว็บ (public) — ต้องไปจำกัดคีย์ใน Google Cloud Console:
#    Application restrictions = HTTP referrers → โดเมน GitHub Pages ของคุณ
#    API restrictions = Generative Language API
#    และใช้ free tier เท่านั้น
# ขอคีย์ที่: https://aistudio.google.com/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=AIzaSy...
