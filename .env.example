# ============================================================
# Grack_Trade — ค่า Supabase ที่ต้องตั้ง
# ============================================================
# หมายเหตุสำคัญ: โปรเจกต์นี้เป็น "ไฟล์ HTML เดียว ไม่มี build step (ไม่ใช้ Node)"
# ดังนั้นจึงไม่ได้อ่านไฟล์ .env จริง ๆ ตอนรัน
#
# ให้นำค่า 2 ตัวข้างล่างนี้ไป "วางในโค้ด" ที่บล็อก [SUPABASE CONFIG]
# ซึ่งอยู่บนสุดของไฟล์  GradeCalculatorApp.jsx  (แล้วรัน python3 build.py)
# หรือแก้ที่ index.html ตรง ๆ ก็ได้ (ค้นหาคำว่า SUPABASE_URL)
#
# anon key เป็น public key ใส่ในหน้าเว็บได้ (ไม่มีระบบล็อกอิน · RLS เปิด public อยู่แล้ว)
# หาได้ที่: Supabase project → Project Settings → API
# ============================================================

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ------------------------------------------------------------
# (ไม่บังคับ) Gemini — AI วิเคราะห์/แชทเรื่องอาชีพ
# ⚠️ ตั้งเป็น "secret ของ Supabase Edge Function" ไม่ใช่ใส่ในโค้ดหน้าเว็บ
#    (คีย์อยู่ฝั่ง server จึงไม่หลุดขึ้น repo และ GitHub ไม่บล็อก)
# วิธีตั้ง (ดู README):
#    Dashboard: Supabase → Edge Functions → Secrets → เพิ่ม GEMINI_API_KEY
#    CLI:       supabase secrets set GEMINI_API_KEY=xxxx GEMINI_MODEL=gemini-2.0-flash
# ขอคีย์ (ที่มีโควตา) ด้วยบัญชี Gmail ส่วนตัว: https://aistudio.google.com/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=AIzaSy...            # ← เป็น Supabase secret ไม่ใช่ในโค้ด
GEMINI_MODEL=gemini-2.0-flash       # ไม่บังคับ
